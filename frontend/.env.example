# Development Environment Variables
# Copy this file to .env for shared defaults (e.g. production API URL for builds).

# API Base URL — used by `npm run build` and as fallback for dev.
# For local dev with `npm run dev`, use `.env.development` (committed) which points
# to http://localhost:9000/api so you must run the Django backend locally.
VITE_API_BASE_URL=https://api.mrdsphub.in/api

# Canonical / Open Graph base URL (no trailing slash). Used for SEO meta tags.
# Production:
# VITE_SITE_URL=https://mrdsphub.in
# Local dev: omit to use window.location.origin
